#!/usr/bin/env bash
set -eufo pipefail

. "${HOME}/.local/share/chezmoi/lib/log.sh"

{{ $brews := list
      "atuin"
      "awscli"
      "bat"
      "cfn-lint"
      "colima"
      "copilot-cli"
      "curl"
      "direnv"
      "docker"
      "docker-credential-helper-ecr"
      "eza"
      "fd"
      "git"
      "git-absorb"
      "git-cliff"
      "git-delta"
      "gitleaks"
      "glab"
      "glances"
      "gnupg"
      "gradle"
      "gradle-completion"
      "helm"
      "hugo"
      "hopenpgp-tools"
      "jenv"
      "jq"
      "k9s"
      "kubectx"
      "kubernetes-cli"
      "liquibase"
      "maven"
      "neovim"
      "nvm"
      "pinentry-mac"
      "pipx"
      "ripgrep"
      "skaffold"
      "snyk"
      "step"
      "tmux"
      "uv"
      "watch"
      "wget"
      "ykman"
      "yq"
      "yubikey-personalization"
      "z" -}}

{{ $casks := list
     "alfred"
     "bruno"
     "dbeaver-community"
     "font-fira-code"
     "font-jetbrains-mono"
     "ghostty"
     "gimp"
     "insomnia"
     "jetbrains-toolbox"
     "rectangle-pro" -}}

log::info "installing brews"
brew bundle --file=/dev/stdin <<EOF
{{ range ($brews | sortAlpha | uniq) -}}
brew "{{ . }}"
{{ end -}}
{{ range ($casks | sortAlpha | uniq) -}}
cask "{{ . }}"
{{ end -}}
EOF
log::info::complete
