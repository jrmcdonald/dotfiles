#!/usr/bin/env bash
set -eufo pipefail

. "${CHEZMOI_SOURCE_DIR:-${HOME}/.local/share/chezmoi}/lib/log.sh"

{{- if not .work }}
exit 0
{{- end }}

# mise-managed Java and Node versions.
# Bare version strings resolve to temurin-* because
# java.shorthand_vendor = "temurin" is set in ~/.config/mise/config.toml
log::info "installing java versions via mise"
mise install java@17
mise install java@21
mise install java@25
mise use --global java@21
log::info::complete
