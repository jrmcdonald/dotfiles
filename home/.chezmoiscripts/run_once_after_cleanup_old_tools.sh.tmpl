#!/usr/bin/env bash
set -eufo pipefail

. "${CHEZMOI_SOURCE_DIR:-${HOME}/.local/share/chezmoi/home}/../lib/log.sh"

function cleanup::remove_if_exists() {
  local name="${1}"
  local path="${2}"
  if [ -d "${path}" ]; then
    log::info "removing ${name}"
    rm -rf "${path}"
    log::info::complete
  fi
}

function main() {
  cleanup::remove_if_exists "nvm (replaced by mise)"        "${HOME}/.nvm"
  cleanup::remove_if_exists "jenv (replaced by mise)"       "${HOME}/.jenv"
  cleanup::remove_if_exists "sdkman (replaced by mise)"     "${HOME}/.sdkman"
  cleanup::remove_if_exists "zgen (replaced by sheldon)"    "${HOME}/.zgen"
  cleanup::remove_if_exists "slimzsh (replaced by sheldon)" "${HOME}/.slimzsh"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
